# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=your-meta-permanent-access-token
WHATSAPP_PHONE_ID=your-whatsapp-phone-number-id

# Meta App Secret — used to verify X-Hub-Signature-256 on incoming webhooks.
# Find it in: Meta Developer Console → Your App → App Settings → Basic → App Secret
WHATSAPP_APP_SECRET=your-meta-app-secret

# Webhook verification token — you choose this string, must match Meta dashboard
VERIFY_TOKEN=your-verify-token

# Dashboard
DASHBOARD_URL=https://your-agents-dashboard.up.railway.app
WEBHOOK_SECRET=your-shared-webhook-secret

# Optional
APP_URL=https://your-chatbot.up.railway.app

# Gmail SMTP — for sending booking confirmation emails
# Use a Gmail App Password (not your account password):
# Google Account → Security → 2-Step Verification → App passwords
GMAIL_ADDRESS=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

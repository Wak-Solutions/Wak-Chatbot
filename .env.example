# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Meta WhatsApp Cloud API
# The phone number ID — not the phone number itself. Used to route outbound messages.
WHATSAPP_PHONE_ID=your-whatsapp-phone-number-id

# Webhook verification token — you choose this string, must match Meta dashboard
VERIFY_TOKEN=your-verify-token

# Dashboard
DASHBOARD_URL=https://your-agents-dashboard.up.railway.app

# WEBHOOK_SECRET is no longer required — auth is now per-company via the
# webhook_secret column in the companies table. This variable is unused;
# remove it from Railway environment variables.
# WEBHOOK_SECRET=

# Optional
APP_URL=https://your-chatbot.up.railway.app

# Manager notification email
MANAGER_EMAIL=manager@yourdomain.com
